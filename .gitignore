# Environment — never commit secrets
.env

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# Testing
.pytest_cache/
.coverage
htmlcov/

# IDE
.idea/
.vscode/

# Docker
*.log

# Alembic
alembic/versions/*.pyc

# Terraform — never commit real secrets or local state
terraform/terraform.tfvars
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/tfplan
terraform/*.tfstate
terraform/*.tfstate.backup
