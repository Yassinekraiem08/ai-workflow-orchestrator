# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/workflow_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Authentication
# Comma-separated list of valid API keys
API_KEYS=dev-key-changeme
# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=changeme-in-production

# App
APP_ENV=development
LOG_LEVEL=INFO

# Orchestrator
MAX_TOOL_RETRIES=3
MAX_CELERY_RETRIES=3
STEP_TIMEOUT_SECONDS=60
CELERY_RETRY_DELAY_SECONDS=30

# LLM model routing
# Fast model: classifier, planner, replanner, fallback (~10x cheaper)
LLM_MODEL_FAST=gpt-4o-mini
# Strong model: executor agent (reasoning-heavy tool calls)
LLM_MODEL_STRONG=gpt-4o

# Human-in-the-loop
# Classifier confidence below this threshold → run held for human review
CONFIDENCE_THRESHOLD=0.65

# Observability (OpenTelemetry → Jaeger)
OTEL_ENABLED=false
OTLP_ENDPOINT=http://localhost:4318/v1/traces
