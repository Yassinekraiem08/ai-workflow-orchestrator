# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/workflow_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# App
APP_ENV=development
LOG_LEVEL=INFO

# Orchestrator
MAX_TOOL_RETRIES=3
MAX_CELERY_RETRIES=3
STEP_TIMEOUT_SECONDS=60
CELERY_RETRY_DELAY_SECONDS=30
